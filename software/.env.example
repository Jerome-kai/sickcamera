OPENAI_API_KEY=replace-with-your-api-key-or-vercel-gateway-key
# Leave empty for api.openai.com; set to your gateway for proxied billing,
# e.g. https://ai-gateway.vercel.sh/v1 for the Vercel AI Gateway.
OPENAI_BASE_URL=
IMAGE_GEN_HOST=0.0.0.0
IMAGE_GEN_PORT=8000
# edits = /v1/images/edits (direct api.openai.com with gpt-image-2)
# chat  = /v1/chat/completions with a multimodal image model — required for gateways
#         that don't expose /v1/images/edits (e.g. the Vercel AI Gateway)
IMAGE_GEN_API=edits
# With a gateway, model names need a provider prefix. Vercel gateway recipe:
#   IMAGE_GEN_API=chat + IMAGE_GEN_MODEL=google/gemini-2.5-flash-image
IMAGE_GEN_MODEL=gpt-image-2
IMAGE_GEN_QUALITY=low
IMAGE_GEN_SIZE=1536x1024
IMAGE_GEN_OUTPUT_FORMAT=jpeg
IMAGE_GEN_OUTPUT_COMPRESSION=85
IMAGE_GEN_TIMEOUT_SECONDS=90
IMAGE_GEN_INPUT_WIDTH=1280
IMAGE_GEN_INPUT_HEIGHT=960
MAGIC_MODE_ENABLED=1
# With a gateway, prefix this too, e.g. openai/gpt-4.1-mini
MAGIC_MODE_MODEL=gpt-4.1-mini
MAGIC_MODE_TIMEOUT_SECONDS=30

# Hardware target: opi = Orange Pi Zero 2 (this fork's default), pi = original Raspberry Pi stack
IMAGEGENCAM_HW=opi

# USB camera (V4L2 index: /dev/video0 -> 0)
CAMERA_DEVICE=0
CAMERA_PREVIEW_WIDTH=480
CAMERA_PREVIEW_HEIGHT=360
CAMERA_FRAME_RATE=10
CAMERA_ROTATION_DEGREES=0
CAMERA_SWAP_RED_BLUE=1
CAMERA_STALE_FRAME_TIMEOUT_SECONDS=2.0

# GPIO backend: auto = try gpiod (kernel 5.10+), fall back to sysfs (legacy 4.9 kernel).
# sysfs pull-ups are set via /dev/mem (root) — see HARDWARE.md "Legacy kernel" section.
GPIO_BACKEND=auto
GPIO_SYSFS_BASE=0
SUNXI_SET_PULLUPS=1

# ST7796 SPI display (Orange Pi Zero 2 wiring — see HARDWARE.md)
GPIO_CHIP=/dev/gpiochip0
DISPLAY_SPI_BUS=1
# Legacy 4.9 kernel image exposes /dev/spidev1.1 -> DEV=1; modern images expose
# /dev/spidev1.0 -> DEV=0. Check with: ls /dev/spidev*
DISPLAY_SPI_DEV=1
DISPLAY_SPI_HZ=40000000
DISPLAY_DC_PIN=74
DISPLAY_RST_PIN=71
DISPLAY_BACKLIGHT_PIN=79
DISPLAY_INVERT=0
DISPLAY_ROTATION_180=0
# pillarbox = keep 4:3 UI centered with black side bars; stretch = fill 480x320
DISPLAY_FIT=pillarbox

# Buttons (gpiod line numbers; PCn = 64+n, PHn = 224+n)
BUTTON_SHUTTER_PIN=73
BUTTON_UI_DOWN_PIN=70
BUTTON_UI_UP_PIN=69
BUTTON_UI_ALBUM_PIN=72
BUTTON_UI_PROMPT_PIN=78

# Hot shoe flash trigger via MOC3021 opto-triac (see HARDWARE.md "Hot shoe").
# GPIO --330R--> MOC3021 pin 1, pin 2 -> GND; pin 6 -> shoe center contact,
# pin 4 -> shoe metal frame. Fires on every capture when enabled.
HOTSHOE_ENABLED=0
# PC11 = header pin 12, gpiod line 75
HOTSHOE_PIN=75
# How long the trigger stays asserted. A xenon flash latches the triac and
# fires instantly; LED lights that only shine while triggered stay on long
# enough to cover the captured frame.
HOTSHOE_PULSE_MS=200

# Wi-Fi (NetworkManager interface name)
WIFI_INTERFACE=wlan0

# PiSugar battery pack (not used on the Orange Pi build)
PISUGAR_ENABLED=0
PISUGAR_POWER_BUTTON_SHUTTER=0
